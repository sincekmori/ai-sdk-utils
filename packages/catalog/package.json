{
  "name": "ai-sdk-catalog",
  "version": "0.5.0",
  "description": "Manage Vercel AI SDK providers, models, and roles from one declarative config file — direct vendors or your own LLM gateway, batteries included.",
  "keywords": [
    "ai",
    "ai-sdk",
    "catalog",
    "config",
    "llm",
    "model",
    "provider",
    "registry",
    "vercel"
  ],
  "homepage": "https://github.com/sincekmori/ai-sdk-utils/tree/main/packages/catalog#readme",
  "bugs": {
    "url": "https://github.com/sincekmori/ai-sdk-utils/issues"
  },
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sincekmori/ai-sdk-utils.git",
    "directory": "packages/catalog"
  },
  "files": [
    "dist",
    "schema.json"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.cts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./package.json": "./package.json",
    "./schema.json": "./schema.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "generate-schema": "node scripts/generate-schema.ts",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^4.0.9",
    "@ai-sdk/cohere": "^4.0.5",
    "@ai-sdk/deepseek": "^3.0.5",
    "@ai-sdk/google": "^4.0.9",
    "@ai-sdk/groq": "^4.0.5",
    "@ai-sdk/mistral": "^4.0.6",
    "@ai-sdk/openai": "^4.0.8",
    "@ai-sdk/openai-compatible": "^3.0.5",
    "@ai-sdk/perplexity": "^4.0.6",
    "@ai-sdk/provider-utils": "^5.0.5",
    "@ai-sdk/xai": "^4.0.8",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "ai": "^7.0.17"
  },
  "peerDependencies": {
    "ai": ">=7.0.0"
  },
  "engines": {
    "node": ">=24"
  }
}
