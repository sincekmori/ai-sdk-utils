{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "$schema": {
      "type": "string"
    },
    "providers": {
      "minItems": 1,
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "vendor": {
            "anyOf": [
              {
                "type": "string",
                "enum": [
                  "anthropic",
                  "openai",
                  "openai-compatible",
                  "mistral",
                  "cohere",
                  "groq",
                  "xai",
                  "deepseek",
                  "perplexity",
                  "google"
                ]
              },
              {
                "type": "object",
                "properties": {
                  "id": {
                    "type": "string",
                    "enum": [
                      "anthropic",
                      "openai",
                      "openai-compatible",
                      "mistral",
                      "cohere",
                      "groq",
                      "xai",
                      "deepseek",
                      "perplexity",
                      "google"
                    ]
                  },
                  "baseURL": {
                    "type": "string",
                    "minLength": 1
                  },
                  "apiKey": {
                    "anyOf": [
                      {
                        "type": "string",
                        "minLength": 1
                      },
                      {
                        "type": "object",
                        "properties": {
                          "envVarName": {
                            "type": "string",
                            "minLength": 1
                          }
                        },
                        "required": ["envVarName"],
                        "additionalProperties": false
                      }
                    ]
                  },
                  "name": {
                    "type": "string",
                    "minLength": 1
                  },
                  "headers": {
                    "type": "object",
                    "propertyNames": {
                      "type": "string",
                      "minLength": 1
                    },
                    "additionalProperties": {
                      "anyOf": [
                        {
                          "type": "string",
                          "minLength": 1
                        },
                        {
                          "type": "object",
                          "properties": {
                            "envVarName": {
                              "type": "string",
                              "minLength": 1
                            }
                          },
                          "required": ["envVarName"],
                          "additionalProperties": false
                        }
                      ]
                    }
                  },
                  "query": {
                    "type": "object",
                    "propertyNames": {
                      "type": "string",
                      "minLength": 1
                    },
                    "additionalProperties": {
                      "type": "string"
                    }
                  }
                },
                "additionalProperties": false
              }
            ]
          },
          "gateway": {
            "type": "object",
            "properties": {
              "baseURL": {
                "type": "string",
                "minLength": 1
              },
              "apiKey": {
                "anyOf": [
                  {
                    "type": "string",
                    "minLength": 1
                  },
                  {
                    "type": "object",
                    "properties": {
                      "envVarName": {
                        "type": "string",
                        "minLength": 1
                      }
                    },
                    "required": ["envVarName"],
                    "additionalProperties": false
                  }
                ]
              },
              "headers": {
                "type": "object",
                "propertyNames": {
                  "type": "string",
                  "minLength": 1
                },
                "additionalProperties": {
                  "anyOf": [
                    {
                      "type": "string",
                      "minLength": 1
                    },
                    {
                      "type": "object",
                      "properties": {
                        "envVarName": {
                          "type": "string",
                          "minLength": 1
                        }
                      },
                      "required": ["envVarName"],
                      "additionalProperties": false
                    }
                  ]
                }
              },
              "query": {
                "type": "object",
                "propertyNames": {
                  "type": "string",
                  "minLength": 1
                },
                "additionalProperties": {
                  "type": "string"
                }
              },
              "backends": {
                "type": "object",
                "propertyNames": {
                  "type": "string",
                  "minLength": 1
                },
                "additionalProperties": {
                  "type": "object",
                  "properties": {
                    "vendor": {
                      "type": "string",
                      "enum": [
                        "anthropic",
                        "openai",
                        "openai-compatible",
                        "mistral",
                        "cohere",
                        "groq",
                        "xai",
                        "deepseek",
                        "perplexity",
                        "google"
                      ]
                    },
                    "pathTemplate": {
                      "type": "string",
                      "minLength": 1
                    },
                    "actionMap": {
                      "type": "object",
                      "propertyNames": {
                        "type": "string"
                      },
                      "additionalProperties": {
                        "type": "string"
                      }
                    },
                    "name": {
                      "type": "string",
                      "minLength": 1
                    },
                    "headers": {
                      "type": "object",
                      "propertyNames": {
                        "type": "string",
                        "minLength": 1
                      },
                      "additionalProperties": {
                        "anyOf": [
                          {
                            "type": "string",
                            "minLength": 1
                          },
                          {
                            "type": "object",
                            "properties": {
                              "envVarName": {
                                "type": "string",
                                "minLength": 1
                              }
                            },
                            "required": ["envVarName"],
                            "additionalProperties": false
                          }
                        ]
                      }
                    },
                    "query": {
                      "type": "object",
                      "propertyNames": {
                        "type": "string",
                        "minLength": 1
                      },
                      "additionalProperties": {
                        "type": "string"
                      }
                    }
                  },
                  "required": ["vendor", "pathTemplate"],
                  "additionalProperties": false
                }
              }
            },
            "required": ["baseURL", "backends"],
            "additionalProperties": false
          },
          "settings": {
            "type": "object",
            "properties": {
              "maxOutputTokens": {
                "type": "integer",
                "exclusiveMinimum": 0,
                "maximum": 9007199254740991
              },
              "temperature": {
                "type": "number"
              },
              "topP": {
                "type": "number"
              },
              "topK": {
                "type": "integer",
                "minimum": -9007199254740991,
                "maximum": 9007199254740991
              },
              "presencePenalty": {
                "type": "number"
              },
              "frequencyPenalty": {
                "type": "number"
              },
              "stopSequences": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "seed": {
                "type": "integer",
                "minimum": -9007199254740991,
                "maximum": 9007199254740991
              },
              "providerOptions": {
                "type": "object",
